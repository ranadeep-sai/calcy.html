<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ultimate Pro Calculator</title>
    <style>
        * { -webkit-tap-highlight-color: transparent !important; outline: none !important; }
        :root { --bg: #eef2ff; --panel: #ffffff; --text: #1e293b; --btn-gray: #e2e8f0; }
        .dark-theme { --bg: #0f172a; --panel: #1e293b; --text: #f8fafc; --btn-gray: #334155; }
        
        body { background-color: var(--bg); color: var(--text); font-family: sans-serif; display: flex; flex-direction: column; align-items: center; min-height: 100vh; margin: 0; padding: 20px; transition: background 0.3s; }
        #viewport { width: 340px; display: flex; flex-direction: column; height: 100vh; }
        #output-zone { flex-grow: 1; overflow-y: auto; padding: 10px; text-align: right; }
        
        .calculator { background: var(--panel); padding: 15px; border-radius: 20px; box-shadow: 0 -10px 25px rgba(0,0,0,0.1); margin-bottom: 20px; }
        #display { width: 100%; height: 50px; background: #f1f5f9; border: none; text-align: right; margin-bottom: 15px; border-radius: 10px; font-size: 1.5rem; padding: 10px; box-sizing: border-box; }
        
        /* Currency UI */
        .conv-box { display: none; gap: 5px; margin-bottom: 10px; }
        select { padding: 8px; border-radius: 8px; border: 1px solid var(--btn-gray); background: var(--panel); color: var(--text); }
        
        .grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; }
        button { padding: 12px 5px; border: none; border-radius: 8px; background: var(--btn-gray); color: var(--text); cursor: pointer; font-weight: 600; transition: all 0.2s; }
        button:hover { transform: scale(1.05); filter: brightness(1.1); }
        button:active { transform: scale(0.95); background: var(--btn-gray) !important; }
        
        .equals { background: #f8fafc; color: #1e293b; grid-row: span 2; border: 1px solid #cbd5e1; }
        .history-item { font-size: 0.9rem; padding: 5px; border-bottom: 1px solid #ccc; list-style: none; }
    </style>
</head>
<body>

<audio id="clickSound" src="https://www.image2url.com/r2/default/audio/1782053996151-1b515acc-0dac-471b-b272-04f8048be389.mp3"></audio>

<div id="viewport">
    <div id="output-zone">
        <h3>History 🕒</h3>
        <ul id="historyList" style="padding:0;"></ul>
    </div>

    <div class="calculator">
        <div id="convPanel" class="conv-box">
            <select id="fromCur"></select>
            <select id="toCur"></select>
            <button onclick="performConversion()">Go</button>
        </div>

        <div style="display:grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 5px; margin-bottom: 10px;">
            <button onclick="toggleTheme()">🌙</button>
            <button onclick="toggleMode()" id="modeBtn">DEG</button>
            <button onclick="clearHistory()">Clear</button>
            <button onclick="document.getElementById('convPanel').style.display = 'flex'">💱</button>
        </div>
        <input type="text" id="display" placeholder="0">
        <div class="grid">
            <button onclick="playClick(); appendTo('Math.PI')">π</button><button onclick="playClick(); appendTo('Math.E')">e</button><button onclick="playClick(); clearDisplay()">AC</button><button onclick="playClick(); backspace()">⌫</button><button onclick="playClick(); appendTo('/')">/</button>
            <button onclick="playClick(); appendTo('Math.sin(')">sin</button><button onclick="playClick(); appendTo('Math.cos(')">cos</button><button onclick="playClick(); appendTo('Math.tan(')">tan</button><button onclick="playClick(); appendTo('Math.log10(')">log</button><button onclick="playClick(); appendTo('*')">×</button>
            <button onclick="playClick(); appendTo('Math.sqrt(')">√</button><button onclick="playClick(); appendTo('Math.log(')">ln</button><button onclick="playClick(); appendTo('(')">(</button><button onclick="playClick(); appendTo(')')">)</button><button onclick="playClick(); appendTo('-')">-</button>
            <button onclick="playClick(); appendTo('7')">7</button><button onclick="playClick(); appendTo('8')">8</button><button onclick="playClick(); appendTo('9')">9</button><button onclick="playClick(); appendTo('**')">^</button><button onclick="playClick(); appendTo('+')">+</button>
            <button onclick="playClick(); appendTo('4')">4</button><button onclick="playClick(); appendTo('5')">5</button><button onclick="playClick(); appendTo('6')">6</button><button onclick="playClick(); appendTo('%')">%</button><button onclick="playClick(); calculate()" class="equals">=</button>
            <button onclick="playClick(); appendTo('1')">1</button><button onclick="playClick(); appendTo('2')">2</button><button onclick="playClick(); appendTo('3')">3</button><button onclick="playClick(); appendTo('0')">0</button>
            <button onclick="playClick(); appendTo('.')">.</button>
        </div>
    </div>
</div>

<script>
    const display = document.getElementById('display');
    const API_KEY = '6591f34a3669760cf55931de'; // PASTE KEY HERE

    // Populate currencies on load
    async function init() {
        const res = await fetch(`https://v6.exchangerate-api.com/v6/${API_KEY}/codes`);
        const data = await res.json();
        const from = document.getElementById('fromCur');
        const to = document.getElementById('toCur');
        data.supported_codes.forEach(([code]) => {
            from.innerHTML += `<option value="${code}">${code}</option>`;
            to.innerHTML += `<option value="${code}">${code}</option>`;
        });
    }
    init();

    async function performConversion() {
        let amt = display.value;
        let from = document.getElementById('fromCur').value;
        let to = document.getElementById('toCur').value;
        let res = await fetch(`https://v6.exchangerate-api.com/v6/${API_KEY}/pair/${from}/${to}/${amt}`);
        let data = await res.json();
        display.value = data.conversion_result;
    }

    function playClick() { const s = document.getElementById('clickSound'); s.currentTime=0; s.play(); }
    function toggleTheme() { document.body.classList.toggle('dark-theme'); }
    function toggleMode() { let b = document.getElementById('modeBtn'); b.textContent = b.textContent === 'DEG' ? 'RAD' : 'DEG'; }
    function appendTo(val) { display.value += val; }
    function clearDisplay() { display.value = ''; }
    function clearHistory() { document.getElementById('historyList').innerHTML = ''; }
    function backspace() { display.value = display.value.slice(0, -1); }
    function calculate() { try { let res = eval(display.value); display.value = res; } catch { display.value = "Error"; } }
</script>
</body>
</html>
